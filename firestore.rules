{
  "entities": {
    "Customer": {
      "title": "Customer",
      "description": "Customer information",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "gst": { "type": "string" },
        "balance": { "type": "number" },
        "address": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "created_date": { "type": "string" }
      },
      "required": ["name", "phone", "status"]
    },
    "Vendor": {
      "title": "Vendor",
      "description": "Vendor information",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "gst": { "type": "string" },
        "outstanding": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "email": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["name", "phone", "status"]
    },
    "Product": {
      "title": "Product",
      "description": "Product or Service information",
      "type": "object",
      "properties": {
        "sku": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "stock": { "type": "number" },
        "hsn_code": { "type": "string" },
        "type": { "type": "string", "enum": ["goods", "service"] },
        "unit": { "type": "string" },
        "tax_preference": { "type": "string", "enum": ["taxable", "non-taxable"] },
        "track_inventory": { "type": "boolean" }
      },
      "required": ["name", "sku"]
    },
    "AccountingDocument": {
      "title": "Accounting Document",
      "description": "Invoices, Estimates, Bills, POs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["invoice", "estimate", "bill", "purchase_order"] },
        "number": { "type": "string" },
        "related_entity_id": { "type": "number" },
        "related_entity_name": { "type": "string" },
        "date": { "type": "string" },
        "due_date": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["type", "number", "related_entity_id", "total", "status"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expenses",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "vendor": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["category", "amount", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Collection of customers"
    },
    "/vendors/{vendorId}": {
      "schema": "Vendor",
      "description": "Collection of vendors"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/documents/{documentId}": {
      "schema": "AccountingDocument",
      "description": "Collection of accounting documents"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Collection of expenses"
    }
  }
}
